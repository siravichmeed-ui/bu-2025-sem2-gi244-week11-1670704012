# Unity .gitignore
# Recommended .gitignore for Unity projects
# Source: https://github.com/github/gitignore/blob/main/Unity.gitignore

# OS generated files
.DS_Store
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini

# Visual Studio / MonoDevelop / Rider / VSCode
.vs/
.vscode/
.idea/
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.csproj
*.unityproj
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity generated folders
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
UserSettings/
MemoryCaptures/
sysinfo.txt
CrashReports/

# Built application files
*.apk
*.aab
*.unitypackage
*.app
*.exe

# Asset Store tools
Assets/AssetStoreTools*

# Gradle / Android Studio
.gradle/
*.gradle
*.keystore

# Other files to ignore
*.stacktrace
*.log
*.cache
*.pidb.meta
